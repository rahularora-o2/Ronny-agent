# ─── Ronny Agent Config ───────────────────────────────
# Copy this file as .env and fill in your keys

# Claude API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Server port
PORT=3000

# Your name (for personalized responses)
USER_NAME=Rahul

# ─── Google Calendar (via Apps Script — no OAuth needed!) ─
# Follow the setup to paste the script into Google Apps Script
# and deploy as web app. Paste the URL here.
GOOGLE_APPS_SCRIPT_URL=

# ─── Alexa / Smart Home ──────────────────────────────
# IFTTT Webhook key (for triggering Alexa routines)
IFTTT_WEBHOOK_KEY=

# ─── Deep Links (pre-filled, customize as needed) ────
UBER_DEEPLINK=uber://?action=setPickup&pickup=my_location
OLA_DEEPLINK=olacabs://app/launch
ZOMATO_DEEPLINK=zomato://order
SWIGGY_DEEPLINK=swiggy://
BLINKIT_DEEPLINK=blinkit://
MYGATE_DEEPLINK=mygate://
